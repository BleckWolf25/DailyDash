<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>

<VBox fx:id="cardRoot" spacing="8" styleClass="task-card" xmlns:fx="http://javafx.com/fxml/1">

    <HBox alignment="CENTER_LEFT" spacing="8">
        <Label fx:id="categoryTag" styleClass="tag-chip, tag-default" text="GENERAL"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="idLabel" styleClass="task-id" text="TASK-000"/>
    </HBox>

    <Label fx:id="titleLabel" styleClass="task-title" wrapText="true"/>

    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="task-footer">
        <Label fx:id="priorityLabel" styleClass="priority-chip, priority-medium"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="dueDateLabel" styleClass="due-date"/>
    </HBox>

</VBox>
