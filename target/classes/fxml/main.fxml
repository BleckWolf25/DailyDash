<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21" 
            fx:controller="com.dailydash.controller.MainController" 
            stylesheets="@../css/styles.css"
            styleClass="main-root">

    <!-- LEFT SIDEBAR NAVIGATION RAIL -->
    <left>
        <VBox spacing="8" styleClass="sidebar-rail" prefWidth="230">
            <padding><Insets top="20" right="16" bottom="20" left="16"/></padding>
            
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="DAILYDASH" styleClass="sidebar-title"/>
            </HBox>
            <Region prefHeight="10"/>

            <Label text="ACTIVE BOARD" styleClass="sidebar-section-label"/>
            <ComboBox fx:id="projectSelector" prefWidth="200" styleClass="sidebar-project-selector"/>
            <Region prefHeight="14"/>

            <Label text="WORKSPACE" styleClass="sidebar-section-label"/>
            <Button fx:id="navHomeBtn" text="Home" onAction="#showHome" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button fx:id="navProjectsBtn" text="Projects" onAction="#showProjects" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button fx:id="navBoardBtn" text="Active Board" onAction="#showBoard" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button fx:id="navAutomationsBtn" text="Automations" onAction="#showAutomations" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button fx:id="navAnalysisBtn" text="Analytics" onAction="#showAnalysis" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            
            <Region VBox.vgrow="ALWAYS"/>

            <Label text="PREFERENCES" styleClass="sidebar-section-label"/>
            <Button fx:id="navSettingsBtn" text="Settings" onAction="#showSettings" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
            <Button fx:id="themeToggleButton" text="Light Mode" onAction="#handleToggleTheme" styleClass="sidebar-theme-button" maxWidth="Infinity"/>
        </VBox>
    </left>

    <!-- CENTER MULTI-PAGE STACK CONTAINER -->
    <center>
        <StackPane fx:id="contentStack" styleClass="content-stack">
            
            <!-- KANBAN BOARD VIEW -->
            <VBox fx:id="boardContainer" spacing="0" styleClass="board-view-root">
                <!-- TOP FILTER & ACTIONS BAR -->
                <HBox spacing="14" alignment="CENTER_LEFT" styleClass="board-top-bar">
                    <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                    <Label text="Project Board" styleClass="page-title"/>
                    <Region prefWidth="12"/>
                    <TextField fx:id="searchField" promptText="Search tasks..." prefWidth="210"/>
                    <ComboBox fx:id="priorityFilter" promptText="All Priorities" prefWidth="135"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Completion:" styleClass="filter-label"/>
                    <ProgressBar fx:id="progressBar" progress="0.0" prefWidth="140" styleClass="board-progress"/>
                    <Label fx:id="progressLabel" text="0%" styleClass="progress-label"/>
                    <Region prefWidth="10"/>
                    <Button text="+ New Task" onAction="#handleNewTask" styleClass="primary-btn"/>
                </HBox>

                <!-- KANBAN COLUMNS -->
                <HBox spacing="20" alignment="TOP_CENTER" styleClass="board-container" VBox.vgrow="ALWAYS">
                    <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>
                    
                    <VBox styleClass="kanban-column" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="8" styleClass="column-header-row">
                            <Label text="To Do" styleClass="column-header"/>
                            <Label fx:id="todoCountLabel" styleClass="column-count-badge"/>
                        </HBox>
                        <ListView fx:id="todoListView" VBox.vgrow="ALWAYS" styleClass="task-list"/>
                    </VBox>

                    <VBox styleClass="kanban-column" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="8" styleClass="column-header-row">
                            <Label text="In Progress" styleClass="column-header"/>
                            <Label fx:id="inProgressCountLabel" styleClass="column-count-badge"/>
                        </HBox>
                        <ListView fx:id="inProgressListView" VBox.vgrow="ALWAYS" styleClass="task-list"/>
                    </VBox>

                    <VBox styleClass="kanban-column" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="8" styleClass="column-header-row">
                            <Label text="Done" styleClass="column-header"/>
                            <Label fx:id="doneCountLabel" styleClass="column-count-badge"/>
                        </HBox>
                        <ListView fx:id="doneListView" VBox.vgrow="ALWAYS" styleClass="task-list"/>
                    </VBox>
                </HBox>
            </VBox>
            
        </StackPane>
    </center>
</BorderPane>
