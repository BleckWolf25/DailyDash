# Handle line endings automatically for files detected as text
# and leave binary files untouched.
* text=auto

# Denote all files that are truly text and should have normalized line endings
*.java text eol=lf
*.fxml text eol=lf
*.css text eol=lf
*.sql text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Denote binary files which should not be modified
*.db binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
