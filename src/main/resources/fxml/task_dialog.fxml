<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="18" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dailydash.controller.TaskDialogController" stylesheets="@../css/styles.css" styleClass="dialog-root">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <!-- Header Banner -->
    <VBox spacing="4" styleClass="dialog-header-banner">
        <Label fx:id="dialogTitleLabel" text="Task Editor" styleClass="dialog-title"/>
        <Label fx:id="dialogSubtitleLabel" text="Update markdown description, category tag, priority, or deadline." styleClass="dialog-subtitle"/>
    </VBox>

    <VBox spacing="14" VBox.vgrow="ALWAYS">
        <!-- Title Input -->
        <VBox spacing="6">
            <Label text="Task Title" styleClass="field-label"/>
            <TextField fx:id="titleField" promptText="Enter task title..." styleClass="task-edit-input"/>
        </VBox>

        <!-- Category, Priority, Due Date row -->
        <HBox spacing="14">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Category Tag" styleClass="field-label"/>
                <TextField fx:id="categoryField" promptText="e.g. Work, Personal" styleClass="task-edit-input"/>
            </VBox>

            <VBox spacing="6" prefWidth="135">
                <Label text="Priority" styleClass="field-label"/>
                <ComboBox fx:id="priorityComboBox" prefWidth="135" styleClass="task-edit-combo"/>
            </VBox>

            <VBox spacing="6" prefWidth="145">
                <Label text="Due Date" styleClass="field-label"/>
                <DatePicker fx:id="dueDatePicker" prefWidth="145" styleClass="task-edit-date"/>
            </VBox>
        </HBox>

        <!-- Description Area -->
        <VBox spacing="6" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="Markdown Description &amp; Notes" styleClass="field-label"/>
                <Label text="Supports **bold**, *italic*, # headers, - lists" styleClass="markdown-hint-badge"/>
            </HBox>
            <TextArea fx:id="descriptionArea" promptText="Write markdown formatted description or checklists..." prefRowCount="8" wrapText="true" styleClass="task-edit-textarea" VBox.vgrow="ALWAYS"/>
        </VBox>
    </VBox>

    <!-- Bottom Action Bar -->
    <HBox spacing="12" alignment="CENTER_RIGHT" styleClass="dialog-action-bar">
        <Button text="Cancel" onAction="#handleCancel" styleClass="btn-secondary"/>
        <Button text="Save Task" onAction="#handleSave" styleClass="primary-btn"/>
    </HBox>
</VBox>
